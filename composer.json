{
    "name": "bunqueue/client",
    "description": "Official PHP client for the bunqueue job queue server (native TCP protocol, msgpack)",
    "type": "library",
    "license": "MIT",
    "keywords": ["queue", "jobs", "worker", "bunqueue", "background-jobs"],
    "homepage": "https://bunqueue.dev",
    "require": {
        "php": ">=8.1",
        "rybakit/msgpack": "^0.9"
    },
    "autoload": {
        "psr-4": {
            "Bunqueue\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bunqueue\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Egeo Minotti"
        }
    ],
    "support": {
        "issues": "https://github.com/egeominotti/bunqueue/issues",
        "source": "https://github.com/egeominotti/bunqueue/tree/main/sdk/php"
    },
    "config": {
        "sort-packages": true
    }
}
